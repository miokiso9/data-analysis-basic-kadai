        "import numpy as np\n",
        "\n",
        "A = np.array([[0, 1], [2, 3], [4, 5]])\n",
        "B = np.array([[0, 1, 2, 3], [4, 5, 6, 7]])\n",
        "result=np.dot(A, B)\n",
        "max_value = np.max(result)\n",
        "\n",
        "print(\"A*B:\",result)\n",
        "print(\"Maximum value:\", max_value)"
      ],
